# Backend API
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/medicare

# Auth
JWT_SECRET=replace_with_a_long_random_secret
RECORD_ENCRYPTION_KEY=replace_with_a_long_random_encryption_key

# Frontend URLs
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# Gmail email for password reset and two-factor authentication
# EMAIL_PASS must be a Gmail App Password. Spaces are accepted and removed by the app.
EMAIL=yourgmail@gmail.com
EMAIL_PASS=your_16_character_gmail_app_password
EMAIL_FROM=MediCare <yourgmail@gmail.com>

# Recommended for Vercel/serverless deployments because it sends over HTTPS instead of SMTP.
# Set EMAIL_FROM to your verified sender, for example: MediCare <noreply@yourdomain.com>
RESEND_API_KEY=

# Alternative HTTPS email provider.
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@yourdomain.com

# Optional custom SMTP alternative
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your_16_character_gmail_app_password

# Payments, optional locally
RAZORPAY_KEY=
RAZORPAY_SECRET=

# AI diagnosis suggestions, optional
GROQ_API_KEY=

# SMS reminders and alerts, optional
TWILIO_SID=
TWILIO_AUTH=
TWILIO_PHONE=
